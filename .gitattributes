* text=auto

# Source code: keep Linux-style LF
*.py text eol=lf
*.sh text eol=lf
*.cu text eol=lf
*.cuh text eol=lf
*.cpp text eol=lf
*.c text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.ico binary

*.pth binary
*.pth.tar binary
*.pt binary
*.ckpt binary
*.npy binary
*.npz binary